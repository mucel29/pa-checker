// EXAMPLE MODULE CONFIG --- CHANGE LATER

{
  "temp_path": "./.checker_temp",
  "run_valgrind": true,

  // Please avoid cyclic macros
  "macros": {
    "MACRO": "test123",
    "TEST_DIR": "$SRC_DIR/teste",
    "TEST_TEST_DIR": "$TEST_DIR/teste2"
  },

  "ref_checker": {
    "run_after": [],
    "input_path": "./path/to/exec", // might convert to enums?
    "tests": [
      {
        "displayName": "Test 01",
        "file": "out1",
        "args": ["task1", "Ana", "-m", "-n=100", "--file=$SRC_DIR/teste/dir2/in1.txt", "--out=$OUT"],
        "score": 2
      },
      {
        "displayName": "Test 02",
        "file": "out2",
        "args": ["task1", "Ana", "are", "mere", "--file=$SRC_DIR/teste/dir1/dir4/in2.txt", "--out=$OUT"],
        "score": 2
      },
      {
        "displayName": "Test 03",
        "file": "out3",
        "args": ["task1", "argument1", "argument2", "-ab", "--file=$SRC_DIR/teste/dir1/in3.txt", "--out=$OUT"],
        "score": 2
      },
      {
        "displayName": "Test 04",
        "file": "out4",
        "args": ["task1", "argument2", "-bc", "-d", "--file=$SRC_DIR/teste/dir1/dir4/in4.txt", "--out=$OUT"],
        "score": 2
      },
      {
        "displayName": "Test 05",
        "file": "out5",
        "args": ["task1", "argument", "--arg", "-b", "100", "--file=$SRC_DIR/teste/in5.txt", "--out=$OUT"],
        "score": 2
      },
      {
        "displayName": "Test 06",
        "file": "out6",
        "args": ["task2", "$SRC_DIR/teste", "--out=$OUT"],
        "score": 2
      },
      {
        "displayName": "Test 07",
        "file": "out7",
        "args": ["task2", "$SRC_DIR/teste", "-r", "--out=$OUT"],
        "score": 2
      },
      {
        "displayName": "Test 08",
        "file": "out8",
        "args": ["task2", "$SRC_DIR/teste", "-h", "--out=$OUT"],
        "score": 2
      },
      {
        "displayName": "Test 09",
        "file": "out9",
        "args": ["task2", "$SRC_DIR/teste", "-rh", "--out=$OUT"],
        "score": 2
      },
      {
        "displayName": "Test 10",
        "file": "out10",
        "args": ["task2", "$SRC_DIR/teste/dir1/dir4", "--out=$OUT"],
        "score": 2
      }
    ]
  },
  "commit_checker": {
    "run_after": [],
    "minCommits": 5,
    "useFormat": true,
    "score": 10
  },
  "memory_checker": {
    "run_after": [],
    "maxWarnings": 10,
    "maxLeak": 100, // MB
    "score": 5
  },
  "style_checker": {
    "run_after": ["ref_checker", "memory_checker"],
    "score_threshold": 60,
    "thresholds": [
      {
        "under": 5,
        "score": 10
      },
      {
        "under": 15,
        "score": 8
      },
      {
        "under": 45,
        "score": 4
      },
      {
        "under": 70,
        "score": 2
      }
    ]
  }
}
